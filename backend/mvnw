# Maven Wrapper Script for Unix/Linux/macOS
# Generated for CAHCET Placement System — Spring Boot 3.2
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_OPTS" ] ; then
  MAVEN_OPTS="-Xmx1024m"
fi

# Find the project base directory
findBaseDir() {
  SCRIPT="$0"
  while [ -h "$SCRIPT" ] ; do
    ls=$(ls -ld "$SCRIPT")
    link=$(expr "$ls" : '.*-> \(.*\)$')
    if expr "$link" : '/.*' > /dev/null; then
      SCRIPT="$link"
    else
      SCRIPT="$(dirname "$SCRIPT")/$link"
    fi
  done
  BASE_DIR="$(dirname "$SCRIPT")"
  echo "$(cd "$BASE_DIR" && pwd)"
}

BASE_DIR=$(findBaseDir)
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$BASE_DIR}"

WRAPPER_DIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"
WRAPPER_PROPERTIES="$WRAPPER_DIR/maven-wrapper.properties"

# Read distribution URL
if [ -r "$WRAPPER_PROPERTIES" ]; then
  DISTRIBUTION_URL=$(grep distributionUrl "$WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')
fi

DISTRIBUTION_URL="${DISTRIBUTION_URL:-https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip}"

# Download location
M2_HOME="${M2_HOME:-$HOME/.m2}"
DIST_DIR="$M2_HOME/wrapper/dists"

DISTRIBUTION_NAME=$(basename "$DISTRIBUTION_URL" .zip)
DIST_PATH="$DIST_DIR/$DISTRIBUTION_NAME"

# Download Maven if not already present
if [ ! -d "$DIST_PATH/bin" ]; then
  echo "Downloading Maven $DISTRIBUTION_NAME..."
  mkdir -p "$DIST_PATH"
  TMPFILE="$DIST_PATH/download.zip"

  if command -v curl > /dev/null 2>&1; then
    curl -fsSL -o "$TMPFILE" "$DISTRIBUTION_URL" || { echo "ERROR: Download failed. Please install Maven manually."; exit 1; }
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$TMPFILE" "$DISTRIBUTION_URL" || { echo "ERROR: Download failed. Please install Maven manually."; exit 1; }
  else
    echo "ERROR: Neither curl nor wget found. Please install Maven 3.9.x manually."
    exit 1
  fi

  unzip -q "$TMPFILE" -d "$DIST_DIR" && rm -f "$TMPFILE"
  echo "Maven downloaded successfully."
fi

# Locate mvn binary
MAVEN_HOME=$(ls -d "$DIST_DIR/$DISTRIBUTION_NAME/apache-maven-"* 2>/dev/null | head -1)
if [ -z "$MAVEN_HOME" ]; then
  MAVEN_HOME="$DIST_PATH"
fi

MVN_CMD="$MAVEN_HOME/bin/mvn"

if [ ! -x "$MVN_CMD" ]; then
  chmod +x "$MVN_CMD" 2>/dev/null
fi

exec "$MVN_CMD" "$@"
